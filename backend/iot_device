#include <WiFi.h>
#include <HTTPClient.h>
#include <WebSocketsClient.h>
#include "driver/i2s.h"

// ---------------- CONFIG ----------------
const char* ssid = "AdarshOppo";
const char* password = "17032005";

const char* serverIP = "10.37.200.110";
const int serverPort = 5000;

const char* PATIENT_ID = "69a810ef46b0895ac985c4f4"; 
String consultationId = "";

// ---------------- I2S ----------------
#define I2S_WS   25
#define I2S_SCK  26
#define I2S_SD   22

#define I2S_PORT I2S_NUM_0
#define SAMPLE_RATE 8000
#define BUFFER_LEN 512

#define CHUNK_DURATION_SEC 2
#define CHUNK_SAMPLES (SAMPLE_RATE * CHUNK_DURATION_SEC)   // 16000
#define CHUNK_BYTES (CHUNK_SAMPLES * 2)                    // 32000

#define RECORD_TIME 8
#define STATUS_LED 2

WebSocketsClient webSocket;

// Buffers
int32_t i2sData[BUFFER_LEN];
int16_t converted[BUFFER_LEN];
int16_t chunkBuffer[CHUNK_SAMPLES];

int chunkOffset = 0;
int chunkIndex = 0;

bool isRecording = false;
bool wasRecording = false;

// FreeRTOS Queue for HTTP uploads
QueueHandle_t uploadQueue;

typedef struct {
  int chunkIndex;
  int16_t* data;
} UploadMessage;

void uploadTask(void *pvParameters) {
  UploadMessage msg;
  while (true) {
    if (xQueueReceive(uploadQueue, &msg, portMAX_DELAY)) {
      HTTPClient http;
      String url = "http://" + String(serverIP) + ":" + String(serverPort) +
                   "/api/iot/upload/" + consultationId + "?index=" + String(msg.chunkIndex);

      http.begin(url);
      http.addHeader("Content-Type", "application/octet-stream");

      int res = http.POST((uint8_t*)msg.data, CHUNK_BYTES);
      http.end();

      Serial.printf("Chunk %d sent via HTTP, res=%d\n", msg.chunkIndex, res);
      free(msg.data);
    }
  }
}

void webSocketEvent(WStype_t type, uint8_t * payload, size_t length) {
  switch(type) {
    case WStype_DISCONNECTED:
      Serial.println("[WSc] Disconnected!");
      break;
    case WStype_CONNECTED:
      Serial.printf("[WSc] Connected to url: %s\n", payload);
      break;
    case WStype_TEXT:
      {
        String msg = (char*)payload;
        if (msg == "START") {
          isRecording = true;
          Serial.println("Received START signal");
        } else if (msg == "STOP") {
          isRecording = false;
          Serial.println("Received STOP signal");
        }
      }
      break;
  }
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);
  pinMode(STATUS_LED, OUTPUT);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected");
  Serial.println(WiFi.localIP());

  // I2S Config
  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_32BIT, // IMPORTANT
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_I2S,
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 8,
    .dma_buf_len = BUFFER_LEN
  };

  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_SCK,
    .ws_io_num = I2S_WS,
    .data_out_num = I2S_PIN_NO_CHANGE,
    .data_in_num = I2S_SD
  };

  i2s_driver_install(I2S_PORT, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_PORT, &pin_config);

  Serial.println("I2S Ready");

  // Create Upload Task
  uploadQueue = xQueueCreate(5, sizeof(UploadMessage));
  xTaskCreatePinnedToCore(uploadTask, "Upload Task", 8192, NULL, 1, NULL, 0);
}

// ---------------- LOOP ----------------
void loop() {

  if (consultationId == "") {
    // Fetch consultation ID
    HTTPClient http;
    String url = "http://" + String(serverIP) + ":" + String(serverPort) + "/api/iot/active-consultation/" + String(PATIENT_ID);
    
    http.begin(url);
    int code = http.GET();

    if (code == 200) {
      String payload = http.getString();
      int keyIdx = payload.indexOf("\"consultationId\"");
      if (keyIdx != -1) {
        int colonIdx = payload.indexOf(':', keyIdx);
        int quote1 = payload.indexOf('"', colonIdx);
        int quote2 = payload.indexOf('"', quote1 + 1);
        if (quote1 != -1 && quote2 != -1) {
          consultationId = payload.substring(quote1 + 1, quote2);
          Serial.println("Linked to Consultation ID: " + consultationId);
          
          // Initialize WebSocket ONLY after we have the ID!
          String wsPath = "/iot-stream?consultationId=" + consultationId + "&device=esp32";
          webSocket.begin(serverIP, serverPort, wsPath.c_str());
          webSocket.onEvent(webSocketEvent);
          Serial.println("WebSocket Initialized!");
        } else {
          Serial.println("Malformed JSON for consultationId");
        }
      } else {
        Serial.println("No consultationId found in payload");
      }
    } else {
      Serial.println("No active consultation. Retrying...");
    }

    http.end();
    if (consultationId == "") {
      delay(3000);
    }
    return;
  }

  webSocket.loop();

  if (!isRecording) {
    if (wasRecording) {
      wasRecording = false;
      digitalWrite(STATUS_LED, LOW);
      
      // Finish request
      HTTPClient http;
      String finishUrl = "http://" + String(serverIP) + ":" + String(serverPort) +
                         "/api/iot/upload/" + consultationId + "/finish";

      http.begin(finishUrl);
      int finishCode = http.POST("");
      http.end();

      Serial.println("Recording Stopped & Finished");
    }
    delay(50);
    return;
  }

  wasRecording = true;
  digitalWrite(STATUS_LED, HIGH);

  size_t bytes_read;

  i2s_read(I2S_PORT, i2sData, sizeof(i2sData), &bytes_read, portMAX_DELAY);

  int samplesRead = bytes_read / 4;

  // Convert 32-bit → 16-bit
  for (int i = 0; i < samplesRead; i++) {
    converted[i] = i2sData[i] >> 14;
  }

  // Debug amplitude
  int maxVal = 0;
  for (int i = 0; i < samplesRead; i++) {
    if (abs(converted[i]) > maxVal) maxVal = abs(converted[i]);
  }
  Serial.println(maxVal);

  // Copy to chunk buffer
  memcpy(&chunkBuffer[chunkOffset], converted, samplesRead * sizeof(int16_t));
  chunkOffset += samplesRead;

  // When chunk full → send
  if (chunkOffset >= CHUNK_SAMPLES) {

    webSocket.sendBIN((uint8_t*)chunkBuffer, CHUNK_BYTES);

    // Queue chunk for background HTTP upload
    int16_t* bufferCopy = (int16_t*)malloc(CHUNK_BYTES);
    if (bufferCopy != NULL) {
      memcpy(bufferCopy, chunkBuffer, CHUNK_BYTES);
      UploadMessage msg;
      msg.chunkIndex = chunkIndex;
      msg.data = bufferCopy;
      
      if (xQueueSend(uploadQueue, &msg, 0) != pdTRUE) {
        Serial.println("Upload queue full! HTTP Chunk dropped.");
        free(bufferCopy);
      }
    } else {
      Serial.println("Malloc failed! HTTP Chunk dropped.");
    }

    chunkIndex++;
    chunkOffset = 0;
  }
}